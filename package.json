{
  "name": "@michaelhartmayer/agentctl",
  "publishConfig": {
    "access": "public"
  },
  "description": "Agent Controller - A unified interface for humans and AI agents",
  "version": "1.0.4",
  "main": "dist/index.js",
  "bin": {
    "agentctl": "./dist/index.js"
  },
  "files": [
    "dist",
    "skills",
    "scripts",
    "agentctl.cmd",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "register:path": "node scripts/register-path.js",
    "unregister:path": "node scripts/unregister-path.js",
    "release": "standard-version",
    "prepublishOnly": "npm run build && npm run test",
    "prepare": "husky"
  },
  "keywords": [
    "cli",
    "agent",
    "ai",
    "automation",
    "framework"
  ],
  "author": "Michael Hartmayer",
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^14.0.3",
    "fs-extra": "^11.3.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.2.3",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^8.57.1",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "husky": "^9.1.7",
    "standard-version": "^9.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
